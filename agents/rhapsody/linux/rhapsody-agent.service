[Unit]
Description=Rhapsody Monitoring Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=/etc/rhapsody-monitoring-agent.env
ExecStart=/usr/bin/python3 /opt/rhapsody-monitoring-agent/rhapsody-agent.py
Restart=always
RestartSec=15
User=root

[Install]
WantedBy=multi-user.target
